<div style="max-width:680px;margin:0 auto;font-family:'Segoe UI',Helvetica,Arial,sans-serif;color:#2c3e50;line-height:1.6;">

    <!-- 顶部品牌栏 -->
    <table width="100%" cellpadding="0" cellspacing="0" style="background:linear-gradient(135deg,#0f2027,#203a43,#2c5364);border-radius:8px 8px 0 0;">
        <tr>
            <td style="padding:24px 32px;">
                <h1 style="margin:0;font-size:22px;font-weight:600;color:#ffffff;letter-spacing:1px;">乾颐堂 NetDevOps</h1>
                <p style="margin:4px 0 0;font-size:13px;color:#8ecae6;font-weight:400;">Syslog 智能分析报告</p>
            </td>
        </tr>
    </table>

    <!-- 正文容器 -->
    <div style="background:#f8f9fa;border:1px solid #dee2e6;border-top:none;border-radius:0 0 8px 8px;padding:28px 32px;">

        <!-- 严重级别分析 -->
        <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:8px;">
            <tr>
                <td style="border-left:4px solid #e74c3c;padding-left:12px;">
                    <h2 style="margin:0;font-size:17px;color:#2c3e50;">Syslog 严重级别分析</h2>
                    <p style="margin:2px 0 0;font-size:12px;color:#7f8c8d;">按日志严重等级统计数量与占比</p>
                </td>
            </tr>
        </table>

        <!-- 表格 + 图表并排布局 -->
        <table width="100%" cellpadding="0" cellspacing="0" style="margin-top:12px;">
            <tr valign="top">
                <!-- 左: 表格 -->
                <td style="width:55%;padding-right:16px;">
                    <table width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;font-size:13px;">
                        <thead>
                            <tr>
                                <th style="background:#2c3e50;color:#ffffff;padding:10px 14px;text-align:left;font-weight:500;border-radius:6px 0 0 0;">严重级别</th>
                                <th style="background:#2c3e50;color:#ffffff;padding:10px 14px;text-align:center;font-weight:500;">数量</th>
                                <th style="background:#2c3e50;color:#ffffff;padding:10px 14px;text-align:center;font-weight:500;border-radius:0 6px 0 0;">百分比</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for s in severity_level_count_html_list %}
                            <tr style="background:{% if loop.index is odd %}#ffffff{% else %}#eef2f7{% endif %};">
                                <td style="padding:9px 14px;border-bottom:1px solid #e9ecef;font-weight:600;color:#e74c3c;">{{ s.name }}</td>
                                <td style="padding:9px 14px;border-bottom:1px solid #e9ecef;text-align:center;">{{ s.log_count }}</td>
                                <td style="padding:9px 14px;border-bottom:1px solid #e9ecef;text-align:center;">{{ s.percent }}%</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </td>
                <!-- 右: 饼状图 -->
                <td style="width:45%;text-align:center;vertical-align:middle;">
                    <img src="cid:{{ severity_level_filename }}" width="280" style="border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1);">
                </td>
            </tr>
        </table>

        <!-- 分隔线 -->
        <hr style="border:none;border-top:1px solid #dee2e6;margin:28px 0;">

        <!-- 设备分析 -->
        <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:8px;">
            <tr>
                <td style="border-left:4px solid #3498db;padding-left:12px;">
                    <h2 style="margin:0;font-size:17px;color:#2c3e50;">Syslog 发送主机分析</h2>
                    <p style="margin:2px 0 0;font-size:12px;color:#7f8c8d;">按设备 IP 统计日志发送数量与占比</p>
                </td>
            </tr>
        </table>

        <table width="100%" cellpadding="0" cellspacing="0" style="margin-top:12px;">
            <tr valign="top">
                <!-- 左: 表格 -->
                <td style="width:55%;padding-right:16px;">
                    <table width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;font-size:13px;">
                        <thead>
                            <tr>
                                <th style="background:#2c3e50;color:#ffffff;padding:10px 14px;text-align:left;font-weight:500;border-radius:6px 0 0 0;">发送主机</th>
                                <th style="background:#2c3e50;color:#ffffff;padding:10px 14px;text-align:center;font-weight:500;">日志数量</th>
                                <th style="background:#2c3e50;color:#ffffff;padding:10px 14px;text-align:center;font-weight:500;border-radius:0 6px 0 0;">百分比</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for d in device_ip_count_html_list %}
                            <tr style="background:{% if loop.index is odd %}#ffffff{% else %}#eef2f7{% endif %};">
                                <td style="padding:9px 14px;border-bottom:1px solid #e9ecef;font-weight:600;color:#3498db;font-family:'Courier New',monospace;">{{ d.ip }}</td>
                                <td style="padding:9px 14px;border-bottom:1px solid #e9ecef;text-align:center;">{{ d.log_count }}</td>
                                <td style="padding:9px 14px;border-bottom:1px solid #e9ecef;text-align:center;">{{ d.percent }}%</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </td>
                <!-- 右: 饼状图 -->
                <td style="width:45%;text-align:center;vertical-align:middle;">
                    <img src="cid:{{ device_ip_filename }}" width="280" style="border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1);">
                </td>
            </tr>
        </table>

        <!-- 页脚 -->
        <hr style="border:none;border-top:1px solid #dee2e6;margin:28px 0 16px;">
        <p style="font-size:11px;color:#adb5bd;text-align:center;margin:0;">
            本邮件由 <strong style="color:#7f8c8d;">乾颐堂 NetDevOps 自动化平台</strong> 自动生成 &nbsp;|&nbsp; Powered by Python + Pygal + Jinja2
        </p>
    </div>
</div>
